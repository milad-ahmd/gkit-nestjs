{
  "name": "@milad-ahmd/gkit-nestjs",
  "version": "1.0.0",
  "description": "Production-grade NestJS/TypeScript toolkit — 24 battle-tested packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js --testTimeout=60000",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "nestjs",
    "toolkit",
    "typescript",
    "retry",
    "cache",
    "circuitbreaker",
    "ratelimit",
    "pubsub",
    "saga",
    "validation"
  ],
  "author": "Milad Ahmadi <miladahmadi803@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/milad-ahmd/gkit-nestjs.git"
  },
  "bugs": {
    "url": "https://github.com/milad-ahmd/gkit-nestjs/issues"
  },
  "homepage": "https://github.com/milad-ahmd/gkit-nestjs#readme",
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.0.0",
    "@testcontainers/redis": "^10.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "testcontainers": "^10.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3"
  }
}
